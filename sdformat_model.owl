        <owl:someValuesFrom rdf:resource="http://sdformat.org/spec/model#Model_Link_Projector_Plugin" />
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:ObjectProperty rdf:about="http://sdformat.org/spec/model#Model_Link_has_Projector">
